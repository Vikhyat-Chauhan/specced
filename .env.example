# Copy to .env and fill in. Never commit .env.

# Claude (teacher generation + LLM/VLM judges). See the claude-api skill for current model IDs.
ANTHROPIC_API_KEY=

# Weights & Biases (training/eval tracking)
WANDB_API_KEY=
WANDB_PROJECT=specced

# Local model serving (Ollama default)
OLLAMA_HOST=http://localhost:11434
SPECCED_MODEL=specced-qwen7b   # name of the served fine-tuned model
